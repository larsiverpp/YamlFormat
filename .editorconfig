root = true

[*.cs]
csharp_style_prefer_primary_constructors = false:silent
resharper_place_record_field_attribute_on_same_line = false

# IDE
# dotnet_diagnostic.IDE0040.severity = none # AddAccessibilityModifiers

# StyleCop Analyzers
dotnet_diagnostic.SA1101.severity = none # PrefixLocalCallsWithThis
dotnet_diagnostic.SA1400.severity = none # AccessModifierMustBeDeclared
dotnet_diagnostic.SA1600.severity = none # ElementsMustBeDocumented
dotnet_diagnostic.SA1633.severity = none # FileMustHaveHeader

# Microsoft.CodeAnalysis.FxCopAnalyzers
dotnet_diagnostic.CA1707.severity = none # Identifiers should not contain underscores
dotnet_diagnostic.CA2007.severity = none # DoNotDirectlyAwaitATaskAnalyzer

# xUnit Analyzers
dotnet_diagnostic.xUnit1041.severity = none # Fixture arguments to test classes must have fixture sources
dotnet_diagnostic.xUnit1045.severity = none # Avoid using TheoryData type arguments that might not be serializable
